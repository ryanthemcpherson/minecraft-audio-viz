{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stages.schema.json",
  "title": "StagesMessage",
  "description": "Response listing all stages with their zone role mappings and configurations.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "stages"
    },
    "v": {
      "type": "string"
    },
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 64,
            "pattern": "^[a-zA-Z0-9_-]+$"
          },
          "id": {
            "type": "string",
            "description": "UUID of the stage"
          },
          "template": {
            "type": "string",
            "description": "Template name used to create the stage"
          },
          "active": {
            "type": "boolean"
          },
          "rotation": {
            "type": "number"
          },
          "anchor": {
            "type": "object",
            "properties": {
              "world": { "type": "string" },
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            },
            "required": ["world", "x", "y", "z"]
          },
          "zones": {
            "type": "object",
            "description": "Map of role name to zone info. Keys are StageZoneRole enum values (e.g. MAIN_STAGE, LEFT_WING).",
            "additionalProperties": {
              "type": "object",
              "properties": {
                "zone_name": {
                  "type": "string",
                  "description": "The underlying visualization zone name"
                },
                "role": {
                  "type": "string",
                  "enum": ["MAIN_STAGE", "LEFT_WING", "RIGHT_WING", "SKYBOX", "AUDIENCE", "BACKSTAGE", "RUNWAY", "BALCONY"]
                },
                "display_name": {
                  "type": "string"
                },
                "entity_count": {
                  "type": "integer",
                  "minimum": 0
                },
                "config": {
                  "$ref": "#/$defs/stage_zone_config"
                }
              },
              "required": ["zone_name", "role"]
            }
          },
          "zone_count": {
            "type": "integer",
            "minimum": 0
          },
          "total_entities": {
            "type": "integer",
            "minimum": 0
          }
        },
        "required": ["name", "id", "template", "active", "zones"]
      }
    },
    "count": {
      "type": "integer",
      "minimum": 0
    }
  },
  "required": ["type", "stages"],
  "$defs": {
    "stage_zone_config": {
      "type": "object",
      "description": "Per-zone configuration within a stage.",
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Visualization pattern identifier"
        },
        "entity_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "render_mode": {
          "type": "string",
          "enum": ["entities", "particles", "hybrid"]
        },
        "block_type": {
          "type": "string"
        },
        "brightness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "glow_on_beat": {
          "type": "boolean"
        },
        "intensity_multiplier": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 3.0
        }
      }
    }
  }
}
