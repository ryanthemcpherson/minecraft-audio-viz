{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "dj-approved.schema.json",
  "title": "DjApprovedMessage",
  "description": "Server notifies browser clients that a pending DJ has been approved.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "dj_approved"
    },
    "v": {
      "type": "string"
    },
    "dj_id": {
      "type": "string",
      "description": "ID of the approved DJ."
    }
  },
  "required": ["type", "dj_id"]
}
