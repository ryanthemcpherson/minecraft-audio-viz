{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "set-bitmap-pattern.schema.json",
  "title": "SetBitmapPatternMessage",
  "description": "Switch the active bitmap pattern for a zone.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "set_bitmap_pattern"
    },
    "v": {
      "type": "string"
    },
    "zone": {
      "type": "string",
      "minLength": 1,
      "description": "Target bitmap zone name"
    },
    "pattern": {
      "type": "string",
      "minLength": 1,
      "description": "Bitmap pattern identifier (e.g. bmp_plasma, bmp_spectrogram)"
    }
  },
  "required": ["type", "zone", "pattern"]
}
