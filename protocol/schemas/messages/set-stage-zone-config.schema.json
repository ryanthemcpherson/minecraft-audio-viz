{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "set-stage-zone-config.schema.json",
  "title": "SetStageZoneConfigMessage",
  "description": "Configure a zone within a stage by its semantic role.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "set_stage_zone_config"
    },
    "v": {
      "type": "string"
    },
    "stage": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[a-zA-Z0-9_-]+$",
      "description": "Name of the stage"
    },
    "role": {
      "type": "string",
      "enum": ["MAIN_STAGE", "LEFT_WING", "RIGHT_WING", "SKYBOX", "AUDIENCE", "BACKSTAGE", "RUNWAY", "BALCONY"],
      "description": "Zone role within the stage"
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "pattern": {
          "type": "string",
          "description": "Visualization pattern identifier"
        },
        "entity_count": {
          "type": "integer",
          "minimum": 1,
          "maximum": 1000
        },
        "render_mode": {
          "type": "string",
          "enum": ["entities", "particles", "hybrid"]
        },
        "block_type": {
          "type": "string"
        },
        "brightness": {
          "type": "integer",
          "minimum": 0,
          "maximum": 15
        },
        "glow_on_beat": {
          "type": "boolean"
        },
        "intensity_multiplier": {
          "type": "number",
          "minimum": 0.1,
          "maximum": 3.0
        }
      }
    }
  },
  "required": ["type", "stage", "role", "config"]
}
