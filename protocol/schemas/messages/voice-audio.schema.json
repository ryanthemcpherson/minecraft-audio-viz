{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "voice-audio.schema.json",
  "title": "VoiceAudioMessage",
  "description": "DJ streams voice audio data to the VJ server, which relays it to voice subscribers.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "type": {
      "const": "voice_audio"
    },
    "v": {
      "type": "string"
    },
    "data": {
      "type": "string",
      "description": "Base64-encoded audio data (PCM or Opus)."
    },
    "seq": {
      "type": "integer",
      "minimum": 0,
      "description": "Sequence number for ordering."
    },
    "codec": {
      "type": "string",
      "enum": ["pcm", "opus"],
      "description": "Audio codec used."
    }
  },
  "required": ["type", "data", "seq"]
}
